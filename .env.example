# g10kz v5 — example environment file.
# Copy to .env and fill in your values.  Never commit .env.

# ── Discord ────────────────────────────────────────────────────────────────────
DISCORD_TOKEN=
OWNER_USER_ID=

# ── LLM ───────────────────────────────────────────────────────────────────────
# Provider: "openrouter" | "mock"
LLM_PROVIDER=openrouter
# Base URL — OpenAI-compatible endpoint (OpenRouter or self-hosted)
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=

# Per-path model selection
LLM_MODEL_SOCIAL=openai/gpt-4o-mini
LLM_MODEL_REASON=openai/gpt-4o
LLM_MODEL_JUDGE=anthropic/claude-3-5-haiku

# Fusion multi-model drafters (comma-separated)
LLM_FUSION_DRAFTERS=openai/gpt-4o,anthropic/claude-3-5-sonnet,google/gemini-2.0-flash

# ── EverOS memory sidecar ──────────────────────────────────────────────────────
# Leave empty to disable memory (NullMemory fallback)
EVEROS_URL=http://localhost:8000

# ── Persona card (SillyTavern V2 JSON) ────────────────────────────────────────
# Leave empty to use built-in stub
PERSONA_CARD_PATH=

# ── Cloudflare AI Search (WebSearchTool) ──────────────────────────────────────
CF_ACCOUNT_ID=
CF_API_TOKEN=

# ── Tuning ────────────────────────────────────────────────────────────────────
PROACTIVE_INACTIVE_SECS=86400
REQUEST_TIMEOUT_SECS=30

# ── Blacklist (comma-separated Discord user snowflakes) ───────────────────────
BLACKLISTED_USERS=

# ── Logging ───────────────────────────────────────────────────────────────────
RUST_LOG=g10kz=info,warn
